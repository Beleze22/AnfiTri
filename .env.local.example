# Connection strings do Postgres (Supabase) — Etapa 2.
# DATABASE_URL: connection pooling (Transaction pooler, porta 6543) — usada em runtime pela aplicação.
# DIRECT_URL: conexão direta (porta 5432) — usada só pelo Prisma para rodar migrations.
DATABASE_URL=
DIRECT_URL=

# Segredo usado para assinar os JWT de gestor e hóspede — preenchido na Etapa 3
JWT_SECRET=

# Segredo que protege as rotas de cron (ex: expiração de pendentes) contra
# chamadas de fora da Vercel — preenchido na Etapa 4
CRON_SECRET=

# Supabase Storage (fotos das hospedagens) — preenchido na Etapa 6.
# SUPABASE_SERVICE_ROLE_KEY tem acesso total ao projeto, nunca expor no client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=property-photos

# Gmail API — parser de e-mail de confirmação do Airbnb (Etapa 7).
# Refresh token gerado via OAuth Playground (one-time setup).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
